        "jsCode": "// Mapeo de agentes desde variables de entorno\nconst staff = {\n  [process.env.STAFF_PABLO_PHONE]: \"Pablo\",\n  [process.env.STAFF_SABRINA_PHONE]: \"Sabrina\",\n  [process.env.STAFF_MAURO_PHONE]: \"Mauro\",\n  [process.env.STAFF_MARIANO_PHONE]: \"Mariano\",\n  [process.env.STAFF_MARTIN_PHONE]: \"Martin\",\n  [process.env.STAFF_CATALINA_PHONE]: \"Catalina\",\n  [process.env.STAFF_FLORENCIA_PHONE]: \"Florencia\"\n};\n\nconst xmlData = $('XML').first().json.TwilioResponse.Call;\nconst numeroAsesor = $('Webhook').first().json.body.To || xmlData.To.replace('+', '').trim();\n\nconst isVoicemail = $('Webhook').first().json.query.voiceMail === \"true\";\nconsole.log(isVoicemail)\nconst vertical =  $('Webhook').first().json.query.vertical || 'General';\nconst duration = $('Webhook').first().json.body.RecordingDuration;\n\nreturn {\n  tipo: isVoicemail ? \"NUEVO MENSAJE DE VOZ\" : \"LLAMADA FINALIZADA\",\n  asunto: `[${isVoicemail ? 'VOICEMAIL' : 'LLAMADA'}] - ${vertical}`,\n  agente: isVoicemail ? \"N/A (Buzón)\" : (staff[numeroAsesor.trim()] || \"Desconocido\"),\n  duracion: `${Math.floor(duration / 60)}m ${duration % 60}s`,\n  cliente: $('Webhook').first().json.body.From || \"Número oculto\",\n  vertical: $('Webhook').first().json.query.vertical === \"Administracion\" ? \"Administración\" : $('Webhook').first().json.query.vertical\n};"
